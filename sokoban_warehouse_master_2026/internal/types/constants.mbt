///|
/// Window width in pixels.
pub let screen_w : Int = 1680

///|
/// Window height in pixels.
pub let screen_h : Int = 960

///|
/// Target frame rate for smooth movement and UI animation.
pub let target_fps : Int = 120

///|
/// Maximum supported board columns.
pub let board_cols : Int = 24

///|
/// Maximum supported board rows.
pub let board_rows : Int = 18

///|
/// Total number of board cells in storage arrays.
pub let board_cells : Int = board_cols * board_rows
