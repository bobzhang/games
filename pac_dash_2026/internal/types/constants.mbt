///|
/// Number of columns in the maze grid.
pub let maze_cols : Int = 21

///|
/// Number of rows in the maze grid.
pub let maze_rows : Int = 23

///|
/// Pixel size of one maze tile.
pub let tile_size : Int = 24

///|
/// Left screen offset for maze rendering.
pub let maze_x : Int = 24

///|
/// Top screen offset for maze rendering.
pub let maze_y : Int = 24

///|
/// Left X coordinate for HUD text block.
pub let hud_x : Int = maze_x + maze_cols * tile_size + 24

///|
/// Window width in pixels.
pub let screen_width : Int = 760

///|
/// Window height in pixels.
pub let screen_height : Int = 610
